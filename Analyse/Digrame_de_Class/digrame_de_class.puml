@startuml
class User {
  id : int
  firstName : string
  lastName : string
  email : string
  phone : string
  passwordHash : string
  profilePhoto : string
  createdAt : datetime
  isVerified : boolean
}

class DriverProfile {
  id : int
  user_id : int
  cinNumber : string
  cinPhoto : string
  cinVerified : boolean
  avgRating : float
  totalTrips : int
}

class Vehicle {
  id : int
  driver_id : int
  brand : string
  model : string
  color : string
  plateNumber : string
  seats : int
}

class Ride {
  id : int
  driver_id : int
  vehicle_id : int
  departureCityId : int
  arrivalCityId : int
  departureTime : datetime
  pricePerSeat : float
  totalSeats : int
  availableSeats : int
  meetingPoint : string
  notes : string
  status : string
  createdAt : datetime
}

class Booking {
  id : int
  ride_id : int
  passenger_id : int
  seatsReserved : int
  status : string
  bookedAt : datetime
}

class Review {
  id : int
  reviewer_id : int
  reviewed_user_id : int
  ride_id : int
  rating : int
  comment : string
  createdAt : datetime
}

class City {
  id : int
  name : string
  region : string
  latitude : float
  longitude : float
}

class Notification {
  id : int
  user_id : int
  type : string
  message : string
  isRead : boolean
  createdAt : datetime
}

User "1" --> "0..1" DriverProfile : has
DriverProfile "1" --> "0..*" Vehicle : owns
DriverProfile "1" --> "0..*" Ride : publishes
User "1" --> "0..*" Booking : makes
Ride "1" --> "0..*" Booking : has
Ride "1" --> "1" Vehicle : uses
Ride --> City : departure
Ride --> City : arrival
User "1" --> "0..*" Review : writes
User "1" --> "0..*" Review : receives
User "1" --> "0..*" Notification : receives
@enduml