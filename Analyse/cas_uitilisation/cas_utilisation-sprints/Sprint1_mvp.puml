@startuml Sprint1

left to right direction
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #EEF4FF
  BorderColor #3A7BD5
}

title BlassaCar - Sprint 1 : MVP

actor Conducteur as C
actor Voyageur as V

rectangle "Sprint 1 - MVP" {
  usecase "S'inscrire" as UC1
  usecase "Se connecter" as UC2
  usecase "Publier un trajet" as UC3
  usecase "Rechercher un trajet" as UC6
  usecase "Reserver une place" as UC7
  usecase "Notification WhatsApp" as UC10
}

C --> UC1
C --> UC2
C --> UC3
C --> UC10

V --> UC1
V --> UC2
V --> UC6
V --> UC7
V --> UC10

UC7 ..> UC10 : <<include>>
UC3 ..> UC10 : <<include>>

@enduml