
@startuml
top to bottom direction

skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #F0F4FF
  BorderColor #3A7BD5
  FontSize 13
}
skinparam ArrowColor #555555
skinparam ArrowFontSize 11

title BlassaCar — Use Case Diagram

actor Driver   as C #lightblue
actor Traveler as V #lightgreen
actor Admin    as A #lightyellow

package "Authentication" {
  usecase "Register" as UC1
  usecase "Login" as UC2
}

package "Ride Management (Driver)" {
  usecase "Post a Ride" as UC3
  usecase "Edit a Ride" as UC4
  usecase "Cancel a Ride" as UC5
}

package "Booking (Traveler)" {
  usecase "Search for a Ride" as UC6
  usecase "Book a Seat" as UC7
  usecase "Cancel a Booking" as UC8
  usecase "Leave a Review" as UC9
}

package "Notifications (System)" {
  usecase "Notify Driver\n(New Booking)" as UC10
  usecase "Notify Traveler\n(Booking Confirmed)" as UC11
  usecase "Notify on\nCancellation" as UC12
}

package "Administration" {
  usecase "Manage Users" as UC13
  usecase "Moderate Rides" as UC14
  usecase "View Statistics" as UC15
}

C --> UC1
C --> UC2
C --> UC3
C --> UC4
C --> UC5

V --> UC1
V --> UC2
V --> UC6
V --> UC7
V --> UC8
V --> UC9

A --> UC13
A --> UC14
A --> UC15

UC7 ..> UC10 : <<include>>
UC7 ..> UC11 : <<include>>
UC8 ..> UC12 : <<include>>
UC5 ..> UC12 : <<include>>
UC9 ..> UC7  : <<extend>>

@enduml
